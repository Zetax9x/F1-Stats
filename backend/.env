# Port (Oracle Cloud may set PORT).
# PORT=8000

# CORS: comma-separated origins that can call this API (your Vercel frontend URLs).
# Add your Vercel deployment URL and preview URLs when you deploy.
# Example: https://f1-stats.vercel.app,https://*.vercel.app
CORS_ORIGINS=http://localhost:3000,https://localhost:3000

# Optional: MongoDB for future live data (ingestor).
# MONGO_CONNECTION_STRING=mongodb://localhost:27017
